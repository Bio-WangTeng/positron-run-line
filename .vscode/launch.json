{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "启动扩展 (VS Code)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "npm: watch"
    },
    {
      "name": "启动扩展 (Positron)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "/Applications/Positron.app/Contents/MacOS/Positron",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "npm: watch"
    }
  ]
}
